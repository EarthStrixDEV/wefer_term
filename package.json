{
  "name": "wefer_term",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix frontend\" \"wait-on tcp:5173 && electron .\"",
    "start": "electron .",
    "build-frontend": "npm run build --prefix frontend",
    "rebuild": "electron-rebuild -f -w node-pty",
    "pack": "npm run build-frontend && electron-builder --dir",
    "dist": "npm run build-frontend && electron-builder --win nsis"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "concurrently": "^10.0.3",
    "electron": "^41.7.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.wefer.aiorchestrator",
    "productName": "Wefer AI Orchestrator",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!frontend/src/**",
      "!frontend/public/**",
      "!frontend/node_modules/**",
      "!frontend/index.html",
      "!frontend/vite.config.js",
      "!frontend/eslint.config.js",
      "!docs/**",
      "!**/*.md"
    ],
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wefer AI Orchestrator"
    }
  }
}
